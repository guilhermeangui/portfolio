@import '../../styles/variables'

@keyframes orb-1
  0%, 100%
    transform translate(0, 0) scale(1)
  50%
    transform translate(40px, -30px) scale(1.1)

@keyframes orb-2
  0%, 100%
    transform translate(0, 0) scale(1)
  50%
    transform translate(-30px, 40px) scale(0.9)

@keyframes orb-3
  0%, 100%
    transform translate(0, 0) scale(1)
  33%
    transform translate(20px, 20px) scale(1.05)
  66%
    transform translate(-20px, -10px) scale(0.95)

@keyframes blink
  0%, 100%
    opacity 1
  50%
    opacity 0

@keyframes scroll-bounce
  0%, 100%
    transform translateX(-50%) translateY(0)
  50%
    transform translateX(-50%) translateY(8px)

@keyframes hero-in
  from
    opacity 0
    transform translateY(24px)
  to
    opacity 1
    transform translateY(0)

.hero
  position relative
  min-height 100vh
  display flex
  align-items center
  overflow hidden
  padding 7rem 0 5rem

  &__bg
    position absolute
    inset 0
    pointer-events none
    overflow hidden

  &__orb
    position absolute
    border-radius 50%
    filter blur(80px)
    opacity 0.35

    &--1
      width 600px
      height 600px
      top -10%
      left -5%
      background unquote("radial-gradient(circle, rgba(var(--accent-rgb), 0.6) 0%, transparent 70%)")
      animation orb-1 12s ease-in-out infinite

    &--2
      width 500px
      height 500px
      bottom -15%
      right -5%
      background unquote("radial-gradient(circle, rgba(var(--accent-2-rgb), 0.5) 0%, transparent 70%)")
      animation orb-2 15s ease-in-out infinite

    &--3
      width 400px
      height 400px
      top 40%
      left 55%
      background unquote("radial-gradient(circle, rgba(var(--accent-rgb), 0.25) 0%, transparent 70%)")
      animation orb-3 18s ease-in-out infinite

  &__grid
    position absolute
    inset 0
    background-image linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px)
    background-size 60px 60px
    mask-image radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%)

  &__content
    position relative
    z-index 1
    max-width 780px

  &__eyebrow
    display inline-flex
    align-items center
    gap 0.6rem
    font-family font-mono
    font-size 0.78rem
    font-weight 500
    color var(--accent-2)
    letter-spacing 0.05em
    margin-bottom 1.5rem
    padding 0.4rem 0.9rem
    background unquote("rgba(var(--accent-2-rgb), 0.08)")
    border 1px solid unquote("rgba(var(--accent-2-rgb), 0.2)")
    border-radius radius-full
    animation hero-in 0.6s ease both
    animation-delay 0.1s

  &__dot
    width 7px
    height 7px
    border-radius 50%
    background var(--accent-2)
    box-shadow 0 0 8px unquote("rgba(var(--accent-2-rgb), 0.8)")
    flex-shrink 0

  &__name
    font-size clamp(3rem, 8vw, 5.5rem)
    font-weight 800
    line-height 1.0
    letter-spacing -0.04em
    color var(--text-primary)
    margin-bottom 0.5rem
    animation hero-in 0.6s ease both
    animation-delay 0.2s

  &__name-last
    display inline-block
    background linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 100%)
    -webkit-background-clip text
    -webkit-text-fill-color transparent
    background-clip text

  &__typewriter
    font-size clamp(1.25rem, 3vw, 1.75rem)
    font-weight 600
    color var(--text-secondary)
    min-height 2.2rem
    margin-bottom 1.5rem
    display flex
    align-items center
    gap 0.1em
    animation hero-in 0.6s ease both
    animation-delay 0.35s

  &__typed
    transition all 0.1s ease

  &__cursor
    color var(--accent)
    font-weight 300
    animation blink 1.1s step-end infinite

  &__description
    font-size 1.1rem
    color var(--text-secondary)
    line-height 1.75
    margin-bottom 2.5rem
    max-width 580px
    animation hero-in 0.6s ease both
    animation-delay 0.5s

  &__actions
    display flex
    align-items center
    flex-wrap wrap
    gap 0.875rem
    margin-bottom 3.5rem
    animation hero-in 0.6s ease both
    animation-delay 0.65s

  &__social-icon
    display flex
    align-items center
    justify-content center
    width 42px
    height 42px
    border-radius radius-full
    border 1.5px solid var(--border)
    color var(--text-secondary)
    transition all transition-base

    &:hover
      border-color var(--accent)
      color var(--accent)
      background var(--accent-glow)
      transform translateY(-2px)

  &__stats
    display flex
    align-items center
    gap 1.5rem
    flex-wrap wrap
    animation hero-in 0.6s ease both
    animation-delay 0.8s

    @media (max-width breakpoint-sm)
      gap 1rem

  &__stat
    text-align left

  &__stat-value
    display block
    font-size 1.6rem
    font-weight 800
    letter-spacing -0.03em
    background linear-gradient(135deg, var(--text-primary) 0%, var(--text-secondary) 100%)
    -webkit-background-clip text
    -webkit-text-fill-color transparent
    background-clip text
    line-height 1.1

  &__stat-label
    font-size 0.72rem
    color var(--text-muted)
    font-weight 500
    text-transform uppercase
    letter-spacing 0.08em
    margin-top 0.2rem

  &__stat-divider
    width 1px
    height 36px
    background var(--border)
    flex-shrink 0

  &__scroll-indicator
    position absolute
    bottom 2.5rem
    left 50%
    transform translateX(-50%)
    display flex
    flex-direction column
    align-items center
    gap 0.4rem
    background none
    border none
    cursor pointer
    animation scroll-bounce 2s ease-in-out infinite

    span
      display block
      width 1.5px
      height 48px
      background linear-gradient(to bottom, var(--accent), transparent)
      border-radius 2px

    @media (max-width breakpoint-md)
      display none
