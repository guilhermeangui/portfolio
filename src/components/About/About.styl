@import '../../styles/variables'

.about
  padding section-padding
  position relative

  &__inner
    display grid
    grid-template-columns 1fr 1.4fr
    gap 5rem
    align-items center

    @media (max-width breakpoint-lg)
      grid-template-columns 1fr
      gap 3rem

  &__image-col
    display flex
    justify-content center

    @media (max-width breakpoint-lg)
      order -1

  &__avatar
    position relative
    display inline-block

  &__avatar-placeholder
    width 280px
    height 280px
    border-radius radius-xl
    background linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 100%)
    display flex
    align-items center
    justify-content center
    font-size 4rem
    font-weight 800
    color white
    letter-spacing -0.02em
    position relative
    z-index 1
    box-shadow var(--shadow-accent)

    @media (max-width breakpoint-sm)
      width 220px
      height 220px
      font-size 3rem

    // NOTE: Replace with:
    // img
    //   width 280px
    //   height 280px
    //   border-radius radius-xl
    //   object-fit cover

  &__avatar-ring
    position absolute
    inset -8px
    border-radius calc(radius-xl + 8px)
    border 2px solid var(--border-accent)
    z-index 0

    &::before
      content ''
      position absolute
      top -4px
      right -4px
      width 20px
      height 20px
      border-radius 50%
      background var(--accent)
      box-shadow 0 0 16px unquote("rgba(var(--accent-rgb), 0.8)")

  &__avatar-badge
    position absolute
    bottom -12px
    left 50%
    transform translateX(-50%)
    background var(--bg-card)
    border 1px solid var(--border)
    border-radius radius-full
    padding 0.4rem 1rem
    font-size 0.78rem
    font-weight 600
    color var(--text-secondary)
    white-space nowrap
    display flex
    align-items center
    gap 0.4rem
    box-shadow var(--shadow-sm)
    z-index 2

  &__text-col
    display flex
    flex-direction column
    gap 1.25rem

  &__body
    font-size 1.0rem
    color var(--text-secondary)
    line-height 1.8

    strong
      color var(--text-primary)
      font-weight 600

  &__title-accent
    background linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 100%)
    -webkit-background-clip text
    -webkit-text-fill-color transparent
    background-clip text

  &__interests
    display flex
    flex-wrap wrap
    gap 0.5rem
    margin-top 0.5rem
