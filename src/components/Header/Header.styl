@import '../../styles/variables'

.header
  position fixed
  top 0
  left 0
  right 0
  z-index 100
  padding 1.25rem 0
  transition all 0.4s cubic-bezier(0.4, 0, 0.2, 1)

  &--scrolled
    padding 0.75rem 0
    background rgba(var(--bg-primary), 0.85)
    backdrop-filter blur(16px) saturate(180%)
    -webkit-backdrop-filter blur(16px) saturate(180%)
    border-bottom 1px solid var(--border)
    box-shadow var(--shadow-sm)

  &__inner
    display flex
    align-items center
    justify-content space-between
    gap 2rem

  &__logo
    font-family font-mono
    font-size 1.1rem
    font-weight 700
    color var(--text-primary)
    text-decoration none
    display flex
    align-items center
    gap 0.1em
    transition color transition-base
    flex-shrink 0

    &:hover
      color var(--accent)

  &__logo-bracket
    color var(--accent)
    font-weight 400

  &__nav
    display flex
    align-items center
    gap 0.25rem
    margin-left auto

    @media (max-width breakpoint-md)
      display none
      position fixed
      inset 0
      flex-direction column
      justify-content center
      align-items center
      gap 2rem
      background var(--bg-primary)
      z-index 99
      padding 2rem

      &--open
        display flex

  &__nav-link
    font-size 0.875rem
    font-weight 500
    color var(--text-secondary)
    padding 0.4rem 0.75rem
    border-radius radius-sm
    transition all transition-base
    text-decoration none

    &:hover
      color var(--accent)
      background var(--accent-glow)

    @media (max-width breakpoint-md)
      font-size 1.5rem
      font-weight 700
      color var(--text-primary)
      padding 0.5rem

  &__cta
    margin-left 0.75rem
    padding 0.5rem 1.25rem
    font-size 0.8rem

    @media (max-width breakpoint-md)
      margin-left 0
      font-size 1rem
      padding 0.75rem 2rem

  &__actions
    display flex
    align-items center
    gap 0.5rem
    flex-shrink 0

  &__theme-toggle
    display flex
    align-items center
    justify-content center
    width 38px
    height 38px
    border-radius radius-full
    border 1.5px solid var(--border)
    background transparent
    color var(--text-primary)
    font-size 1rem
    cursor pointer
    transition all transition-base

    &:hover
      border-color var(--accent)
      background var(--accent-glow)
      color var(--accent)

  &__burger
    display none
    flex-direction column
    justify-content center
    gap 5px
    width 38px
    height 38px
    padding 8px
    border-radius radius-sm
    border 1.5px solid var(--border)
    background transparent
    cursor pointer
    z-index 100
    position relative
    transition all transition-base

    @media (max-width breakpoint-md)
      display flex

    span
      display block
      width 100%
      height 2px
      background var(--text-primary)
      border-radius 2px
      transition all 0.3s ease
      transform-origin center

    &--open
      span:nth-child(1)
        transform translateY(7px) rotate(45deg)

      span:nth-child(2)
        opacity 0
        transform scaleX(0)

      span:nth-child(3)
        transform translateY(-7px) rotate(-45deg)
