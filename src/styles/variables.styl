// ─── CSS Custom Properties (theme tokens) ───────────────────────────────────

:root
  // Dark theme (default)
  --bg-primary        #080B14
  --bg-secondary      #0D1117
  --bg-card           #111827
  --bg-card-hover     #1A2236
  --accent            #7C3AED
  --accent-rgb        124, 58, 237
  --accent-2          #06B6D4
  --accent-2-rgb      6, 182, 212
  --accent-glow       rgba(124, 58, 237, 0.2)
  --text-primary      #E2E8F0
  --text-secondary    #94A3B8
  --text-muted        #4B5563
  --border            rgba(148, 163, 184, 0.08)
  --border-accent     rgba(124, 58, 237, 0.3)
  --shadow-sm         0 2px 8px rgba(0, 0, 0, 0.4)
  --shadow-md         0 8px 32px rgba(0, 0, 0, 0.5)
  --shadow-accent     0 8px 32px rgba(124, 58, 237, 0.25)
  --scrollbar-thumb   #1E293B
  --scrollbar-track   #080B14

[data-theme="light"]
  --bg-primary        #FAFAFA
  --bg-secondary      #F1F5F9
  --bg-card           #FFFFFF
  --bg-card-hover     #F8FAFC
  --accent            #6D28D9
  --accent-rgb        109, 40, 217
  --accent-2          #0891B2
  --accent-2-rgb      8, 145, 178
  --accent-glow       rgba(109, 40, 217, 0.08)
  --text-primary      #0F172A
  --text-secondary    #475569
  --text-muted        #94A3B8
  --border            rgba(15, 23, 42, 0.08)
  --border-accent     rgba(109, 40, 217, 0.25)
  --shadow-sm         0 2px 8px rgba(0, 0, 0, 0.06)
  --shadow-md         0 8px 32px rgba(0, 0, 0, 0.1)
  --shadow-accent     0 8px 32px rgba(109, 40, 217, 0.15)
  --scrollbar-thumb   #CBD5E1
  --scrollbar-track   #F1F5F9

// ─── Stylus variables (for use in styl files) ───────────────────────────────

font-sans = 'Inter', -apple-system, BlinkMacSystemFont, sans-serif
font-mono = 'JetBrains Mono', 'Fira Code', monospace

breakpoint-sm = 640px
breakpoint-md = 768px
breakpoint-lg = 1024px
breakpoint-xl = 1280px

transition-fast  = 0.15s ease
transition-base  = 0.3s ease
transition-slow  = 0.5s ease
transition-theme = 0.4s cubic-bezier(0.4, 0, 0.2, 1)

radius-sm  = 8px
radius-md  = 12px
radius-lg  = 20px
radius-xl  = 28px
radius-full = 9999px

section-padding = 7rem 0
container-max   = 1100px
container-pad   = 0 clamp(1.5rem, 5vw, 4rem)
